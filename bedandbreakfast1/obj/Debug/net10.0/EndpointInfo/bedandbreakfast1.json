{
  "openapi": "3.0.4",
  "info": {
    "title": "bedandbreakfast1",
    "version": "1.0"
  },
  "paths": {
    "/api/Booking/rooms": {
      "get": {
        "tags": [
          "Booking"
        ],
        "responses": {
          "200": {
            "description": "OK"
          }
        }
      }
    },
    "/api/Booking/booking": {
      "post": {
        "tags": [
          "Booking"
        ],
        "parameters": [
          {
            "name": "roomId",
            "in": "query",
            "schema": {
              "type": "integer",
              "format": "int32"
            }
          },
          {
            "name": "checkIn",
            "in": "query",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "checkOut",
            "in": "query",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "HeadsUp",
            "in": "query",
            "schema": {
              "type": "boolean"
            }
          }
        ],
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/Guest"
              }
            },
            "text/json": {
              "schema": {
                "$ref": "#/components/schemas/Guest"
              }
            },
            "application/*+json": {
              "schema": {
                "$ref": "#/components/schemas/Guest"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "OK"
          }
        }
      }
    }
  },
  "components": {
    "schemas": {
      "Guest": {
        "required": [
          "name",
          "phone"
        ],
        "type": "object",
        "properties": {
          "name": {
            "minLength": 1,
            "pattern": "^[a-zA-Z\\s]{2,50}$",
            "type": "string"
          },
          "phone": {
            "minLength": 1,
            "pattern": "^\\+?[0-9]{8,15}$",
            "type": "string"
          }
        },
        "additionalProperties": false
      }
    }
  },
  "tags": [
    {
      "name": "Booking"
    }
  ]
}