{
  "openapi": "3.0.4",
  "info": {
    "title": "WebApplication1",
    "version": "1.0"
  },
  "paths": {
    "/api/Booking/rooms": {
      "get": {
        "tags": [
          "Booking"
        ],
        "responses": {
          "200": {
            "description": "OK"
          }
        }
      }
    },
    "/api/Booking/create": {
      "post": {
        "tags": [
          "Booking"
        ],
        "parameters": [
          {
            "name": "roomId",
            "in": "query",
            "schema": {
              "type": "integer",
              "format": "int32"
            }
          },
          {
            "name": "checkIn",
            "in": "query",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "checkOut",
            "in": "query",
            "schema": {
              "type": "string"
            }
          }
        ],
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/Guest"
              }
            },
            "text/json": {
              "schema": {
                "$ref": "#/components/schemas/Guest"
              }
            },
            "application/*+json": {
              "schema": {
                "$ref": "#/components/schemas/Guest"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "OK"
          }
        }
      }
    },
    "/api/Booking/update/{id}": {
      "put": {
        "tags": [
          "Booking"
        ],
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "integer",
              "format": "int32"
            }
          },
          {
            "name": "checkIn",
            "in": "query",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "checkOut",
            "in": "query",
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "OK"
          }
        }
      }
    },
    "/api/Booking/delete/{id}": {
      "delete": {
        "tags": [
          "Booking"
        ],
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "integer",
              "format": "int32"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "OK"
          }
        }
      }
    }
  },
  "components": {
    "schemas": {
      "Guest": {
        "required": [
          "name",
          "phone"
        ],
        "type": "object",
        "properties": {
          "id": {
            "type": "integer",
            "format": "int32"
          },
          "name": {
            "minLength": 1,
            "pattern": "^[\\p{L}\\s]{2,50}$",
            "type": "string"
          },
          "phone": {
            "minLength": 1,
            "pattern": "^\\+?[0-9]{8,15}$",
            "type": "string"
          }
        },
        "additionalProperties": false
      }
    }
  },
  "tags": [
    {
      "name": "Booking"
    }
  ]
}